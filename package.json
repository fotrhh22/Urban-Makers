{
  "name": "seoul-urban-regeneration-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "etl:boundary": "node --import tsx scripts/fetch_sgis_boundary.ts",
    "etl:geocode": "node --import tsx scripts/geocode_urban_areas.ts && node --import tsx scripts/geocode_anchor_facilities.ts",
    "etl:population": "node --import tsx scripts/fetch_population.ts",
    "etl:living": "node --import tsx scripts/fetch_living_population_recent.ts",
    "etl:complaints": "node --import tsx scripts/fetch_complaints_seoul.ts",
    "etl:illegal-parking": "node --import tsx scripts/process_illegal_parking_file.ts",
    "etl:crime": "node --import tsx scripts/process_crime_stat_file.ts",
    "etl:vacant": "node --import tsx scripts/process_vacant_house_stat_file.ts",
    "etl:urban": "node --import tsx scripts/fetch_publicdata_urban_regen.ts",
    "etl:building": "node --import tsx scripts/fetch_building_hub.ts",
    "etl:building:test": "BUILDING_HUB_START_YEAR=2025 BUILDING_HUB_END_YEAR=2025 ETL_HTTP_TIMEOUT_MS=30000 node --import tsx scripts/fetch_building_hub.ts --test",
    "etl:kosis:inspect": "node --import tsx scripts/inspect_kosis_employee_dimensions.ts",
    "etl:kosis:employee": "node --import tsx scripts/fetch_kosis_employee.ts",
    "etl:build": "node --import tsx scripts/build_dashboard_json.ts && node --import tsx scripts/build_coverage.ts",
    "etl:validate": "npm run inspect:data && npm run validate:geo && npm run validate:dashboard && npm run validate:coverage && npm run validate:no-web-search-log",
    "inspect:data": "node --import tsx scripts/inspect_data.ts",
    "validate:geo": "node --import tsx scripts/validate_geo.ts",
    "validate:dashboard": "node --import tsx scripts/validate_dashboard.ts",
    "validate:coverage": "node --import tsx scripts/validate_data_coverage.ts",
    "validate:no-web-search-log": "node --import tsx scripts/validate_no_web_search_log.ts",
    "etl:naver-datalab-yearly-csv": "tsx scripts/fetch_naver_datalab_yearly_to_csv.ts",
    "etl:all": "npm run etl:population && npm run etl:living && npm run etl:complaints && npm run etl:urban && npm run etl:build && npm run etl:validate"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "@turf/bbox": "^7.2.0",
    "@types/geojson": "^7946.0.16",
    "dotenv": "^16.4.7",
    "iconv-lite": "^0.7.3",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "proj4": "^2.20.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
